prefix_rule(pattern=["npm", "install"], decision="allow")
prefix_rule(pattern=["git", "add", "package.json", "package-lock.json", "src/app/layout.js", "src/app/page.js", "src/components/MarketingNavbar.js", "src/components/PricingSection.js", "tests/performanceArchitecture.test.mjs"], decision="allow")
prefix_rule(pattern=["/usr/bin/bash", "-lc", "npx --yes vercel deploy --prod --yes 2>&1 | sed -n '1,220p'"], decision="allow")
prefix_rule(pattern=["/usr/bin/bash", "-lc", "curl -sS -L https://www.askhere.fun 2>&1 | rg -o \"Student answers, 24/7|_vercel/speed-insights|Askhere|Max\" | sort | uniq -c"], decision="allow")
prefix_rule(pattern=["/usr/bin/bash", "-lc", "curl -I -L -sS https://www.askhere.fun 2>&1 | sed -n '1,24p'"], decision="allow")
prefix_rule(pattern=["npx", "--yes", "lighthouse"], decision="allow")
prefix_rule(pattern=["git", "add", "src/app/globals.css", "tests/performanceArchitecture.test.mjs"], decision="allow")
prefix_rule(pattern=["/usr/bin/bash", "-lc", "curl -sS -L https://www.askhere.fun 2>&1 | rg -o \"fonts.googleapis.com|_vercel/speed-insights|Student answers, 24/7|Askhere\" | sort | uniq -c"], decision="allow")
prefix_rule(pattern=["git", "add", "src/app/api/stripe/checkout/route.js", "src/components/PricingSection.js", "tests/performanceArchitecture.test.mjs"], decision="allow")
prefix_rule(pattern=["gh", "repo", "create"], decision="allow")
prefix_rule(pattern=["gh", "repo", "view"], decision="allow")
prefix_rule(pattern=["flatpak", "install"], decision="allow")
prefix_rule(pattern=["systemctl", "--user"], decision="allow")
prefix_rule(pattern=["rm", "-rf", "/home/burapat/.local/bin/hermes", "/home/burapat/.config/systemd/user/hermes-gateway.service", "/home/burapat/.local/state/hermes", "/home/burapat/.hermes"], decision="allow")
