{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "browseros": {
      "type": "remote",
      "url": "http://127.0.0.1:9000/mcp",
      "enabled": true
    },
    "notebooklm": {
      "type": "local",
      "command": ["notebooklm-mcp"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    }
  },
  "permission" : "allow" 
}
